digraph STYLE_GUIDE {
    // 用 DSL 自身编写的流程 DSL 样式指南

    // 节点类型及其形状示例
    subgraph cluster_node_types {
        label="节点类型与形状";

        // 问题使用菱形
        "这是一个问题吗？" [shape=diamond];

        // 操作使用方框（默认）
        "执行操作" [shape=box];

        // 命令使用纯文本
        "git commit -m 'msg'" [shape=plaintext];

        // 状态使用椭圆
        "当前状态" [shape=ellipse];

        // 警告使用八边形
        "停止：严重警告" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        // 入口和出口使用双圆
        "流程开始" [shape=doublecircle];
        "流程完成" [shape=doublecircle];

        // 各类型示例
        "测试通过吗？" [shape=diamond];
        "先编写测试" [shape=box];
        "npm test" [shape=plaintext];
        "我遇到阻塞" [shape=ellipse];
        "绝不使用 git add -A" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
    }

    // 连线命名约定
    subgraph cluster_edge_types {
        label="连线标签";

        "二元决策？" [shape=diamond];
        "是分支" [shape=box];
        "否分支" [shape=box];

        "二元决策？" -> "是分支" [label="是"];
        "二元决策？" -> "否分支" [label="否"];

        "多项选择？" [shape=diamond];
        "选项 A" [shape=box];
        "选项 B" [shape=box];
        "选项 C" [shape=box];

        "多项选择？" -> "选项 A" [label="条件 A"];
        "多项选择？" -> "选项 B" [label="条件 B"];
        "多项选择？" -> "选项 C" [label="其他情况"];

        "流程 A 完成" [shape=doublecircle];
        "流程 B 开始" [shape=doublecircle];

        "流程 A 完成" -> "流程 B 开始" [label="触发", style=dotted];
    }

    // 命名模式
    subgraph cluster_naming_patterns {
        label="命名模式";

        // 问题以 ? 结尾
        "我应该执行 X 吗？";
        "这可以是 Y 吗？";
        "Z 是否为真？";
        "我已经完成 W 吗？";

        // 操作以动词开头
        "编写测试";
        "搜索既有模式";
        "提交变更";
        "请求帮助";

        // 命令保持原文
        "grep -r 'pattern' .";
        "git status";
        "npm run build";

        // 状态描述当前情况
        "测试失败";
        "构建完成";
        "错误阻塞中";
    }

    // 流程结构模板
    subgraph cluster_structure {
        label="流程结构模板";

        "触发：发生某件事" [shape=ellipse];
        "初始检查？" [shape=diamond];
        "主要操作" [shape=box];
        "git status" [shape=plaintext];
        "再次检查？" [shape=diamond];
        "替代操作" [shape=box];
        "停止：不要这样做" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "流程完成" [shape=doublecircle];

        "触发：发生某件事" -> "初始检查？";
        "初始检查？" -> "主要操作" [label="是"];
        "初始检查？" -> "替代操作" [label="否"];
        "主要操作" -> "git status";
        "git status" -> "再次检查？";
        "再次检查？" -> "流程完成" [label="通过"];
        "再次检查？" -> "停止：不要这样做" [label="发现问题"];
        "替代操作" -> "流程完成";
    }

    // 各形状的使用场景
    subgraph cluster_shape_rules {
        label="何时使用各类形状";

        "选择形状" [shape=ellipse];

        "这是决策吗？" [shape=diamond];
        "使用菱形" [shape=diamond, style=filled, fillcolor=lightblue];

        "这是命令吗？" [shape=diamond];
        "使用纯文本" [shape=plaintext, style=filled, fillcolor=lightgray];

        "这是警告吗？" [shape=diamond];
        "使用八边形" [shape=octagon, style=filled, fillcolor=pink];

        "这是入口或出口吗？" [shape=diamond];
        "使用双圆" [shape=doublecircle, style=filled, fillcolor=lightgreen];

        "这是状态吗？" [shape=diamond];
        "使用椭圆" [shape=ellipse, style=filled, fillcolor=lightyellow];

        "默认：使用方框" [shape=box, style=filled, fillcolor=lightcyan];

        "选择形状" -> "这是决策吗？";
        "这是决策吗？" -> "使用菱形" [label="是"];
        "这是决策吗？" -> "这是命令吗？" [label="否"];
        "这是命令吗？" -> "使用纯文本" [label="是"];
        "这是命令吗？" -> "这是警告吗？" [label="否"];
        "这是警告吗？" -> "使用八边形" [label="是"];
        "这是警告吗？" -> "这是入口或出口吗？" [label="否"];
        "这是入口或出口吗？" -> "使用双圆" [label="是"];
        "这是入口或出口吗？" -> "这是状态吗？" [label="否"];
        "这是状态吗？" -> "使用椭圆" [label="是"];
        "这是状态吗？" -> "默认：使用方框" [label="否"];
    }

    // 好坏示例对比
    subgraph cluster_examples {
        label="好坏示例对比";

        // 正确：具体且形状匹配
        "测试失败" [shape=ellipse];
        "读取错误信息" [shape=box];
        "能复现吗？" [shape=diamond];
        "git diff HEAD~1" [shape=plaintext];
        "绝不忽略错误" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        "测试失败" -> "读取错误信息";
        "读取错误信息" -> "能复现吗？";
        "能复现吗？" -> "git diff HEAD~1" [label="是"];

        // 错误：含糊且形状不匹配
        bad_1 [label="发生问题", shape=box];  // 应使用椭圆（状态）
        bad_2 [label="修复它", shape=box];  // 过于含糊
        bad_3 [label="检查", shape=box];  // 应使用菱形
        bad_4 [label="执行命令", shape=box];  // 应使用带实际命令的纯文本

        bad_1 -> bad_2;
        bad_2 -> bad_3;
        bad_3 -> bad_4;
    }
}
